<component>
    <name>org.freedesktop.IBus.lotus</name>
    <description>Lotus - Vietnamese Input Method Editor for Linux</description>
    <exec>/usr/lib/ibus-lotus/ibus-engine-lotus --ibus</exec>
    <version>1.0.2</version>
    <author>VuQuan &lt;66623851+vuquan2005@users.noreply.github.com&gt;</author>
    <license>GPLv3</license>
    <homepage>https://github.com/vuquan2005/ibus-lotus</homepage>
    <textdomain>ibus-lotus</textdomain>
    <engines>
        <engine>
            <symbol>vi</symbol>
            <name>Lotus</name>
            <language>vi</language>
            <layout>default</layout>
            <longname>Lotus</longname>
            <icon>/usr/share/ibus-lotus/icons/vi.svg</icon>
            <setup>/usr/lib/ibus-lotus/ibus-engine-lotus -gui</setup>
        </engine>
        <engine>
            <symbol>vi</symbol>
            <name>Lotus::Us</name>
            <language>vi</language>
            <layout>us</layout>
            <longname>Lotus (US layout)</longname>
            <icon>/usr/share/ibus-lotus/icons/vi.svg</icon>
            <setup>/usr/lib/ibus-lotus/ibus-engine-lotus -gui</setup>
        </engine>
        <engine>
            <symbol>vi</symbol>
            <name>Lotus::Candy</name>
            <language>vi</language>
            <layout>default</layout>
            <longname>Lotus Candy</longname>
            <icon>/usr/share/ibus-lotus/icons/vi-candy.svg</icon>
            <setup>/usr/lib/ibus-lotus/ibus-engine-lotus -gui</setup>
        </engine>
        <engine>
            <symbol>vi</symbol>
            <name>Lotus::Flag</name>
            <language>vi</language>
            <layout>default</layout>
