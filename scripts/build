# Ibus lotus
ibus_e_name="bin/ibus-engine-lotus"
if [ -z "$VERSION" ]; then
	echo "Error: VERSION environment variable is required. Please run via Makefile." >&2
	exit 1
fi
version="$VERSION"

# Go flags
LDFLAGS="-w -s -X main.Version=${version} -X ibus-lotus/lotusibus.Version=${version}"

# Go flags for FreeBSD
CGO_CFLAGS_FREEBSD="-I/usr/local/include -std=gnu99"
CGO_LDFLAGS_FREEBSD="-L/usr/local/lib -pthread"

case $(uname) in
	"Linux") CGO_ENABLED=1 \
		go build -o ${ibus_e_name} -ldflags "${LDFLAGS}" -mod=vendor
		;;

	"FreeBSD") CGO_ENABLED=1 \
		CGO_CFLAGS=${CGO_CFLAGS_FREEBSD} \
		CGO_LDFLAGS=${CGO_LDFLAGS_FREEBSD} \
		go build -o ${ibus_e_name} -ldflags "${LDFLAGS}" -mod=vendor
		;;
	*) echo "Hiện tại chưa hỗ trợ hệ điều hành này!"
		;;
esac
